---
const { id, nombre, cultura, imagen, tipo, atributos, iconos } = Astro.props;
const href = tipo === 'dios' ? `/panteon/${id}` : tipo === 'criatura' ? `/criaturas/${id}` : `/lugares/${id}`;
---

<a href={href} class="group block bg-fondo/60 backdrop-blur border border-dorado/20 rounded-[28px_8px_28px_8px] overflow-hidden hover:border-dorado/50 hover:-translate-y-1 transition-all duration-300 shadow-lg">
  <div class="w-full h-auto overflow-hidden bg-[#5f735f]">
    <img
      src={imagen}
      alt={nombre}
      class="w-full h-auto object-contain group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="p-5">
    <span class="inline-block bg-dorado/90 text-fondo text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wider mb-2">
      {cultura}
    </span>
    <h3 class="text-lg font-titulos text-titulo mb-2 group-hover:text-dorado transition-colors">{nombre}</h3>
    <div class="flex flex-wrap gap-2 mt-3">
      {atributos.slice(0, 3).map((attr, i) => (
        <span class="text-xs text-texto/70 flex items-center gap-1">
          <i class={`fas ${iconos[i] || 'fa-star'} text-dorado/70`}></i> {attr}
        </span>
      ))}
    </div>
  </div>
</a>